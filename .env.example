EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional: text-to-speech.
EXPO_PUBLIC_GEMINI_API_KEY=

# App payment backend.
# Local dev: leave empty and run `npm run server:api`.
# Production: set to your deployed backend URL, for example:
# EXPO_PUBLIC_PAYMENT_API_URL=https://booknest-api.onrender.com
EXPO_PUBLIC_PAYMENT_API_URL=
EXPO_PUBLIC_ALLOW_LOCAL_PAYMENT_FALLBACK=false

# Backend-only values. Set these on Render/Railway/VPS, not in a public app build.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_server_only_service_role_key
PAYMENT_BANK_ID=970422
PAYMENT_BANK_NAME=MB BANK
PAYMENT_ACCOUNT_NO=your_account_no
PAYMENT_ACCOUNT_NAME=YOUR_ACCOUNT_NAME
PAYMENT_QR_TEMPLATE=compact2
PAYMENT_WEBHOOK_SECRET=replace_with_a_long_random_secret
